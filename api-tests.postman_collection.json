{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "Pokemon API Tests",
    "description": "Sample API tests for the Pokemon API (pokeapi.co) to demonstrate CI/CD with GitHub Actions",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get Pokemon - Pikachu",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response time is acceptable\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "pm.test(\"Response has required fields\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('name');",
              "    pm.expect(jsonData).to.have.property('id');",
              "    pm.expect(jsonData).to.have.property('abilities');",
              "    pm.expect(jsonData).to.have.property('types');",
              "});",
              "",
              "pm.test(\"Pokemon name is correct\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.name).to.eql('pikachu');",
              "});",
              "",
              "pm.test(\"Pokemon has abilities array\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.abilities).to.be.an('array');",
              "    pm.expect(jsonData.abilities.length).to.be.above(0);",
              "});",
              "",
              "// Store pokemon ID for next request",
              "pm.collectionVariables.set(\"pokemon_id\", pm.response.json().id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://pokeapi.co/api/v2/pokemon/pikachu",
          "protocol": "https",
          "host": ["pokeapi", "co"],
          "path": ["api", "v2", "pokemon", "pikachu"]
        },
        "description": "Retrieve information about Pikachu from the Pokemon API"
      },
      "response": []
    },
    {
      "name": "Get Pokemon by ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Content-Type is JSON\", function () {",
              "    pm.response.to.have.header('Content-Type');",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "});",
              "",
              "pm.test(\"Pokemon ID matches request\", function () {",
              "    const jsonData = pm.response.json();",
              "    const requestedId = pm.collectionVariables.get(\"pokemon_id\");",
              "    pm.expect(jsonData.id).to.eql(parseInt(requestedId));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://pokeapi.co/api/v2/pokemon/{{pokemon_id}}",
          "protocol": "https",
          "host": ["pokeapi", "co"],
          "path": ["api", "v2", "pokemon", "{{pokemon_id}}"]
        },
        "description": "Retrieve Pokemon by ID using the ID from the previous request"
      },
      "response": []
    },
    {
      "name": "Get Pokemon Abilities List",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has results array\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('results');",
              "    pm.expect(jsonData.results).to.be.an('array');",
              "});",
              "",
              "pm.test(\"Pagination fields exist\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('count');",
              "    pm.expect(jsonData).to.have.property('next');",
              "});",
              "",
              "pm.test(\"Results have name and url\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.results[0]).to.have.property('name');",
              "    pm.expect(jsonData.results[0]).to.have.property('url');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://pokeapi.co/api/v2/ability?limit=20",
          "protocol": "https",
          "host": ["pokeapi", "co"],
          "path": ["api", "v2", "ability"],
          "query": [
            {
              "key": "limit",
              "value": "20"
            }
          ]
        },
        "description": "Get a paginated list of Pokemon abilities"
      },
      "response": []
    },
    {
      "name": "Get Pokemon Type - Electric",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Type name is electric\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.name).to.eql('electric');",
              "});",
              "",
              "pm.test(\"Has pokemon list\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('pokemon');",
              "    pm.expect(jsonData.pokemon).to.be.an('array');",
              "    pm.expect(jsonData.pokemon.length).to.be.above(0);",
              "});",
              "",
              "pm.test(\"Has damage relations\", function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('damage_relations');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://pokeapi.co/api/v2/type/electric",
          "protocol": "https",
          "host": ["pokeapi", "co"],
          "path": ["api", "v2", "type", "electric"]
        },
        "description": "Get information about the electric type Pokemon"
      },
      "response": []
    },
    {
      "name": "Invalid Pokemon - 404 Test",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 404\", function () {",
              "    pm.response.to.have.status(404);",
              "});",
              "",
              "pm.test(\"Error message is returned\", function () {",
              "    pm.expect(pm.response.text()).to.include('Not Found');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://pokeapi.co/api/v2/pokemon/invalidpokemon999999",
          "protocol": "https",
          "host": ["pokeapi", "co"],
          "path": ["api", "v2", "pokemon", "invalidpokemon999999"]
        },
        "description": "Negative test case - request an invalid Pokemon to verify 404 handling"
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "pokemon_id",
      "value": "25",
      "type": "string"
    }
  ]
}
